<accessibility-service
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:accessibilityEventTypes="typeWindowContentChanged|typeAllMask"
        android:accessibilityFeedbackType="feedbackGeneric"
        android:notificationTimeout="100"
        android:packageNames="org.mozilla.firefox, com.android.systemui"
        android:accessibilityFlags="flagDefault|flagIncludeNotImportantViews|flagReportViewIds|flagRetrieveInteractiveWindows"
        android:canRetrieveWindowContent="true"
        android:canRequestTouchExplorationMode="true"
        android:canRequestEnhancedWebAccessibility="true"
        android:summary="@string/carry_over_service_summary"
        android:description="@string/carry_over_service_description"
        android:settingsActivity=".CarryOverActivity"
/>
